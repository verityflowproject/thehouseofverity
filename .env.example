# ─── VerityFlow Environment Variables ────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your Supabase project URL (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous/public key (safe to expose to the browser; respects RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase service role key — SERVER SIDE ONLY. Bypasses RLS. Never expose publicly.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── Supabase Dashboard Configuration (manual steps) ─────────────────────────
#
# 1. Auth → Providers → Google
#    - Enable the Google provider
#    - Add your Google OAuth Client ID and Client Secret
#    - (Get these from Google Cloud Console → APIs & Services → Credentials)
#
# 2. Google Cloud Console → OAuth 2.0 Client
#    - Authorized redirect URIs must include:
#        https://<your-project-ref>.supabase.co/auth/v1/callback
#    - For local development also add:
#        http://localhost:3000/api/auth/callback
#
# 3. Auth → URL Configuration
#    - Site URL:       https://verityflow.io
#    - Redirect URLs (allowlist):
#        https://verityflow.io/api/auth/callback
#        http://localhost:3000/api/auth/callback   (for local dev)
#
# 4. Database trigger
#    - Run supabase/schema.sql in the Supabase SQL Editor to deploy the
#      provision_vf_user() trigger that auto-creates user profiles with
#      50 free credits on signup.

# ─── App ──────────────────────────────────────────────────────────────────────
# Public base URL of the deployed app (used for Stripe redirect URLs)
NEXT_PUBLIC_BASE_URL=https://verityflow.io

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe webhook secret — from Dashboard → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs for subscription plans (Stripe Dashboard → Products)
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_STUDIO_PRICE_ID=price_...

# Stripe Price IDs for credit packs (one-time purchases)
STRIPE_CREDIT_PACK_500_PRICE_ID=price_...
STRIPE_CREDIT_PACK_1200_PRICE_ID=price_...
STRIPE_CREDIT_PACK_3000_PRICE_ID=price_...
STRIPE_CREDIT_PACK_8000_PRICE_ID=price_...

# ─── AI Model API Keys ────────────────────────────────────────────────────────
# These are managed server-side — never exposed to end users.

# Google Gemini (via @google/generative-ai)
GOOGLE_AI_API_KEY=your-gemini-api-key

# Anthropic Claude (via @anthropic-ai/sdk)
ANTHROPIC_API_KEY=your-anthropic-api-key

# OpenAI (via openai)
OPENAI_API_KEY=your-openai-api-key

# Mistral / Codestral (via @mistralai/mistralai)
MISTRAL_API_KEY=your-mistral-api-key

# Perplexity (via OpenAI-compatible API)
PERPLEXITY_API_KEY=your-perplexity-api-key

# ─── Internal ─────────────────────────────────────────────────────────────────
# Secret for protecting cron/scheduled job endpoints
CRON_SECRET=your-random-cron-secret

# Allowed CORS origins (comma-separated; defaults to * if unset)
CORS_ORIGINS=https://verityflow.io
