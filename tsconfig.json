{
  "compilerOptions": {
    /* ── TypeScript strict mode (VerityFlow) ── */
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],

    /* Module resolution */
    "allowJs": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* Next.js */
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{"name": "next"}],
    "noEmit": true,

    /* Strict checks */
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* Suppress TypeScript 6.0 deprecation noise for baseUrl (Next.js still needs it) */
    "ignoreDeprecations": "6.0",

    /* Path aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
